{
  "name": "@jaggler3/luna-agent",
  "version": "0.0.1",
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "bun run src/index.ts",
    "build": "bun build src/index.ts --target=bun --outdir dist && chmod +x dist/index.js",
    "test": "bun test",
    "prepublishOnly": "bun run build"
  },
  "dependencies": {
    "@opentui/core": "0.2.12"
  },
  "devDependencies": {
    "@types/bun": "^1.3.14"
  },
  "bin": {
    "luna": "./dist/index.js"
  },
  "files": [
    "dist"
  ]
}